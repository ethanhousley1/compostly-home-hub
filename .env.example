# === Supabase (required for signup/login) ===
# Find these in your Supabase project: Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# === Legacy: raw Postgres connection (only needed by api/ serverless functions) ===
# Not required for the browser-based Supabase Auth signup/login flow.
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# === Local development (optional) ===
# Point the Vite dev server at your local Express backend instead of /api proxy.
# Uncomment only if you are NOT using `vite.config.ts` proxy.
# VITE_API_BASE_URL=http://localhost:3000

# Legacy local Express server env vars (used by server/ only):
# PORT=3000
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=compostly
# PGUSER=postgres
# PGPASSWORD=yourpassword
